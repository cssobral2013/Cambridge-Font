@locl2 = [Z.locl z.locl Oacute.locl oacute.locl Cacute.locl cacute.locl Nacute.locl nacute.locl Sacute.locl sacute.locl Zacute.locl zacute.locl Zdotaccent.locl zdotaccent.locl];
@locl3 = [Acircumflexacute acircumflexacute Acircumflexgrave acircumflexgrave Acircumflexhoi acircumflexhoi Abreveacute abreveacute Abrevegrave abrevegrave Abrevehoi abrevehoi Ecircumflexacute ecircumflexacute Ecircumflexgrave ecircumflexgrave Ecircumflexhoi ecircumflexhoi Ocircumflexacute ocircumflexacute Ocircumflexgrave ocircumflexgrave Ocircumflexhoi ocircumflexhoi];
@locl4 = [Igravecyr Decyr Icyr Ishortcyr Elcyr Efcyr vecyr gecyr decyr zhecyr zecyr icyr ishortcyr kacyr elcyr encyr pecyr tecyr efcyr tsecyr checyr shacyr shchacyr hardcyr softcyr yucyr igravecyr];
@locl5 = [Igravecyr.locl Decyr.locl Icyr.locl Ishortcyr.locl Elcyr.locl Efcyr.locl vecyr.locl gecyr.locl decyr.locl zhecyr.locl zecyr.locl icyr.locl ishortcyr.locl kacyr.locl elcyr.locl encyr.locl pecyr.locl tecyr.locl efcyr.locl tsecyr.locl checyr.locl shacyr.locl shchacyr.locl hardcyr.locl softcyr.locl yucyr.locl igravecyr.locl];
@locl6 = [a g exclamdown agrave aacute acircumflex atilde adieresis aring amacron abreve aogonek dcaron dcroat gcircumflex gbreve gdotaccent gcommaaccent Lcaron lcaron tcaron gcaron aringacute adblgrave ainvertedbreve beta theta chi aringbelow gmacron arighthalfring adotbelow ahoi acircumflexacute acircumflexgrave acircumflexhoi acircumflextilde acircumflexdotbelow abreveacute abrevegrave abrevehoi abrevetilde abrevedotbelow ainferior];
@locl7 = [a.locl g.locl exclamdown.locl agrave.locl aacute.locl acircumflex.locl atilde.locl adieresis.locl aring.locl amacron.locl abreve.locl aogonek.locl dcaron.locl dcroat.locl gcircumflex.locl gbreve.locl gdotaccent.locl gcommaaccent.locl Lcaron.locl lcaron.locl tcaron.locl gcaron.locl aringacute.locl adblgrave.locl ainvertedbreve.locl beta.locl theta.locl chi.locl aringbelow.locl gmacron.locl arighthalfring.locl adotbelow.locl ahoi.locl acircumflexacute.locl acircumflexgrave.locl acircumflexhoi.locl acircumflextilde.locl acircumflexdotbelow.locl abreveacute.locl abrevegrave.locl abrevehoi.locl abrevetilde.locl abrevedotbelow.locl ainferior.locl];
@numr1 = [period zero one two three four five six seven eight nine];
@numr2 = [period.numr zero.superior onesuperior twosuperior threesuperior four.superior five.superior six.superior seven.superior eight.superior nine.superior];
#/< otclasses
#< classes

languagesystem DFLT dflt;
languagesystem grek dflt;
languagesystem grek APPH;
languagesystem grek IPPH;
languagesystem cyrl dflt;
languagesystem cyrl SRB ;
languagesystem cyrl MKD ;
languagesystem cyrl BSH ;
languagesystem cyrl BGR ;
languagesystem cyrl BOS ;
languagesystem cyrl CHU ;
languagesystem latn dflt;
languagesystem latn ZZA ;
languagesystem latn SJE ;
languagesystem latn AZE ;
languagesystem latn GAG ;
languagesystem latn UDI ;
languagesystem latn KJJ ;
languagesystem latn PLK ;
languagesystem latn TRK ;
languagesystem latn MOL ;
languagesystem latn ROM ;
languagesystem latn ISM ;
languagesystem latn LSM ;
languagesystem latn NSM ;
languagesystem latn SSM ;
languagesystem latn SKS ;
languagesystem latn TAT ;
languagesystem latn JCT ;
languagesystem latn VIT ;
languagesystem latn CRT ;
languagesystem latn SJU ;
languagesystem latn TLY ;
languagesystem latn KAZ ;
languagesystem latn KMZ ;
languagesystem latn APPH;
languagesystem latn IPPH;
";
tag = Languagesystems;
}
);
features = (
{
code = "  feature locl;
  feature numr;
  feature dnom;
  feature frac;";
tag = aalt;
},
{
code = " # Localized Forms
 script grek; # Greek
 language APPH exclude_dflt; # Phonetic transcription—Americanist conventions
    sub @locl6 by @locl7;
 language IPPH exclude_dflt; # Phonetic transcription—IPA conventions
    sub @locl6 by @locl7;
 script cyrl; # Cyrillic
 language SRB  exclude_dflt; # Serbian
    sub becyr by becyr.locl;
 language MKD  exclude_dflt; # Macedonian
    sub becyr by becyr.locl;
 language BSH  exclude_dflt; # Bashkir
    sub [Gestrokecyr gestrokecyr Zetailcyr zetailcyr] by [Gestrokecyr.locl gestrokecyr.locl Zetailcyr.locl zetailcyr.locl];
    sub [Estailcyr estailcyr] by [Estailcyr.locl estailcyr.locl];
 language BGR  exclude_dflt; # Bulgarian
    sub @locl4 by @locl5;
 language BOS  exclude_dflt;
    sub becyr by becyr.locl;
 language CHU  exclude_dflt; # Chuvash
    sub [Estailcyr estailcyr] by [_1581 _1583];
 script latn; # Latin
 language ZZA  exclude_dflt;
    sub [i i.superior] by [i.locl i.superior.locl];
 language SJE  exclude_dflt;
    sub Eng by Eng.locl;
 language AZE  exclude_dflt; # Azeri
    sub [i i.superior] by [i.locl i.superior.locl];
 language GAG  exclude_dflt; # Gagauz
    sub [i i.superior] by [i.locl i.superior.locl];
 language UDI  exclude_dflt;
    sub [i i.superior] by [i.locl i.superior.locl];
 language KJJ  exclude_dflt;
    sub [i i.superior] by [i.locl i.superior.locl];
 language PLK  exclude_dflt; # Polish
    sub @locl1 by @locl2;
 language TRK  exclude_dflt; # Turkish
    sub [i i.superior] by [i.locl i.superior.locl];
 language MOL  exclude_dflt; # Moldavian
    sub [Scedilla scedilla Tcedilla tcedilla] by [Scommaaccent scommaaccent Tcommaaccent tcommaaccent];
 language ROM  exclude_dflt; # Romanian
    sub [Scedilla scedilla Tcedilla tcedilla] by [Scommaaccent scommaaccent Tcommaaccent tcommaaccent];
 language ISM  exclude_dflt; # Inari Sami
    sub Eng by Eng.locl;
 language LSM  exclude_dflt; # Lule Sami
    sub Eng by Eng.locl;
 language NSM  exclude_dflt; # Northern Sami
    sub Eng by Eng.locl;
 language SSM  exclude_dflt; # Southern Sami
    sub Eng by Eng.locl;
 language SKS  exclude_dflt; # Skolt Sami
    sub Eng by Eng.locl;
 language TAT  exclude_dflt; # Tatar
    sub [i i.superior] by [i.locl i.superior.locl];
 language JCT  exclude_dflt;
    sub [i i.superior] by [i.locl i.superior.locl];
 language VIT  exclude_dflt; # Vietnamese
lookup locl25 {
    sub Acircumflexacute by A circumflexcomb acutecomb;
    sub acircumflexacute by a circumflexcomb acutecomb;
    sub Acircumflexgrave by A circumflexcomb gravecomb;
    sub acircumflexgrave by a circumflexcomb gravecomb;
    sub Acircumflexhoi by A circumflexcomb hookabovecomb;
    sub acircumflexhoi by a circumflexcomb hookabovecomb;
    sub Abreveacute by A brevecomb acutecomb;
    sub abreveacute by a brevecomb acutecomb;
    sub Abrevegrave by A brevecomb gravecomb;
    sub abrevegrave by a brevecomb gravecomb;
    sub Abrevehoi by A brevecomb hookabovecomb;
    sub abrevehoi by a brevecomb hookabovecomb;
    sub Ecircumflexacute by E circumflexcomb acutecomb;
    sub ecircumflexacute by e circumflexcomb acutecomb;
    sub Ecircumflexgrave by E circumflexcomb gravecomb;
    sub ecircumflexgrave by e circumflexcomb gravecomb;
    sub Ecircumflexhoi by E circumflexcomb hookabovecomb;
    sub ecircumflexhoi by e circumflexcomb hookabovecomb;
    sub Ocircumflexacute by O circumflexcomb acutecomb;
    sub ocircumflexacute by o circumflexcomb acutecomb;
    sub Ocircumflexgrave by O circumflexcomb gravecomb;
    sub ocircumflexgrave by o circumflexcomb gravecomb;
    sub Ocircumflexhoi by O circumflexcomb hookabovecomb;
    sub ocircumflexhoi by o circumflexcomb hookabovecomb;
} locl25;
lookup locl26 {
    sub [A E O a e o] circumflexcomb [gravecomb acutecomb hookabovecomb]' by [gravecomb.locl acutecomb.locl hookabovecomb.locl];
    sub [A a] brevecomb [gravecomb acutecomb hookabovecomb]' by [_1514 _1513 _1515];
} locl26;
 language CRT  exclude_dflt; # Crimean Tatar
    sub [i i.superior] by [i.locl i.superior.locl];
 language SJU  exclude_dflt;
    sub Eng by Eng.locl;
 language TLY  exclude_dflt;
    sub [i i.superior] by [i.locl i.superior.locl];
 language KAZ  exclude_dflt; # Kazakh
    sub [i i.superior] by [i.locl i.superior.locl];
 language KMZ  exclude_dflt;
    sub [i i.superior] by [i.locl i.superior.locl];
 language APPH exclude_dflt; # Phonetic transcription—Americanist conventions
    sub @locl6 by @locl7;
 language IPPH exclude_dflt; # Phonetic transcription—IPA conventions
    sub @locl6 by @locl7;";
tag = locl;
},
{
