{
code = "# Ordinals

#> feature
  sub [zero one two three four five six seven eight nine] [A a]' by ordfeminine;
  sub [zero one two three four five six seven eight nine] [O o]' by ordmasculine;
#< feature";
tag = ordn;
},
{
code = "# Scientific Inferiors

#> feature
  sub eight by eight.inferior;
  sub equal by equal.inferior;
  sub five by five.inferior;
  sub four by four.inferior;
  sub nine by nine.inferior;
  sub one by one.inferior;
  sub parenleft by parenleft.inferior;
  sub parenright by parenright.inferior;
  sub plus by plus.inferior;
  sub seven by seven.inferior;
  sub six by six.inferior;
  sub three by three.inferior;
  sub two by two.inferior;
  sub zero by zero.inferior;
#< feature";
tag = sinf;
},
{
code = "# Subscript

#> feature
  sub eight by eight.inferior;
  sub equal by equal.inferior;
  sub five by five.inferior;
  sub four by four.inferior;
  sub nine by nine.inferior;
  sub one by one.inferior;
  sub parenleft by parenleft.inferior;
  sub parenright by parenright.inferior;
  sub plus by plus.inferior;
  sub seven by seven.inferior;
  sub six by six.inferior;
  sub three by three.inferior;
  sub two by two.inferior;
  sub zero by zero.inferior;
#< feature";
tag = subs;
},
{
code = "# Superscript

#> feature
  sub eight by eight.superior;
  sub equal by equal.superior;
  sub five by five.superior;
  sub four by four.superior;
  sub i by i.superior;
  sub n by n.superior;
  sub nine by nine.superior;
  sub one by onesuperior;
  sub parenleft by parenleft.superior;
  sub parenright by parenright.superior;
  sub plus by plus.superior;
  sub seven by seven.superior;
  sub six by six.superior;
  sub three by threesuperior;
  sub two by twosuperior;
  sub zero by zero.superior;
#< feature";
tag = sups;
}
